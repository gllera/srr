{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git :*)",
      "Bash(make :*)",
      "Bash(npm :*)",
      "Bash(npx :*)",
      "Bash(go :*)"
    ]
  }
}
