/packs/
/.vscode/
/.claude/
# ignore /docs/ contents, but keep the delta-tail spec — it is mandatory
# pre-reading (see CLAUDE.md, backend/CLAUDE.md, delta_test.go). Note: git can
# only re-include a file when the parent dir itself is not excluded, hence
# /docs/* rather than /docs/.
#/docs/*
#!/docs/DELTA-TAIL-SPEC.md
/.wrangler/

# Frontend
/frontend/node_modules/
/frontend/.parcel-cache/
/frontend/dist/
/dist/

# The admin console is a Parcel bundle built into backend/webui/dist by
# `make build-admin`. It is generated (like /dist), except for the committed
# placeholder index.html that keeps `go build`/`go vet`/`go test` compiling the
# //go:embed without Node. A local build overwrites the placeholder; restore it
# with `git checkout backend/webui/dist/index.html` before committing.
/backend/webui/dist/*
!/backend/webui/dist/index.html

# design-sync build output (regenerable; see .design-sync/NOTES.md)
/ds-bundle/
