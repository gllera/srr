{
  "name": "frontend",
  "version": "1.0.0",
  "engines": {
    "node": ">=22"
  },
  "source": "src/index.html",
  "targets": {
    "default": {
      "publicUrl": "."
    }
  },
  "scripts": {
    "dev": "concurrently -k npm:serve npm:servep",
    "serve": "SRR_CDN_URL=${SRR_CDN_URL:-http://localhost:3000} parcel serve src/index.html src/design.html --no-cache",
    "servep": "serve --cors -l 3000 \"$(node parcel/resolve-store.js)\"",
    "build": "parcel build --dist-dir ../dist/srrf --no-cache --no-source-maps",
    "smoke": "node e2e/boot-smoke.mjs",
    "test": "vitest run",
    "test-contract": "vitest run --config vitest.contract.config.ts",
    "test-browser": "vitest run --config vitest.browser.config.ts",
    "test-stress": "vitest run --config vitest.stress.config.ts",
    "gen-design": "vitest run --config vitest.design.config.ts",
    "shoot-design": "vitest run --config vitest.design-shots.config.ts",
    "lint": "eslint src/js e2e",
    "format": "prettier --write src \"e2e/**/*.{ts,mjs}\" parcel \"vitest*.ts\" eslint.config.mjs",
    "format-check": "prettier --check src \"e2e/**/*.{ts,mjs}\" parcel \"vitest*.ts\" eslint.config.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "concurrently": "^9.2.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "parcel": "^2.16.4",
    "prettier": "^3.8.1",
    "puppeteer": "25.0.2",
    "serve": "^14.2.6",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
