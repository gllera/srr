{
  "name": "frontend",
  "version": "1.0.0",
  "source": "src/index.html",
  "targets": {
    "default": {
      "distDir": "../dist/srrf",
      "publicUrl": "."
    }
  },
  "scripts": {
    "dev": "concurrently -k npm:serve npm:servep",
    "serve": "parcel serve --no-cache",
    "servep": "npx serve --cors ../packs",
    "build": "parcel build --no-cache --no-source-maps",
    "test": "vitest run",
    "lint": "eslint src/js",
    "format": "prettier --write src",
    "format-check": "prettier --check src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "parcel": "^2.16.4",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
